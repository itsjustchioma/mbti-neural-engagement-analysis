          <datasource-dependencies datasource='federated.0m07frz1lbw2je1as0pel1gpxlrf'>
            <column caption='I – Avg Engagement' datatype='real' name='[Calculation_1665206014264123392]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [IE] = &quot;I&quot; THEN [engagement] END) }' />
            </column>
            <column caption='E – Avg Engagement' datatype='real' name='[Calculation_1665206014264221697]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [IE] = &quot;E&quot; THEN [engagement] END) }' />
            </column>
            <column caption='S – Avg Engagement' datatype='real' name='[Calculation_1665206014264291330]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [SN] = &quot;S&quot; THEN [engagement] END) }' />
            </column>
            <column caption='N – Avg Engagement' datatype='real' name='[Calculation_1665206014264356867]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [SN] = &quot;N&quot; THEN [engagement] END) }' />
            </column>
            <column caption='T – Avg Engagement' datatype='real' name='[Calculation_1665206014264426500]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [Calculation_1665206014266163205] = &quot;T&quot; THEN [engagement] END) }' />
            </column>
            <column caption='TF Label' datatype='string' name='[Calculation_1665206014266163205]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [TF] THEN &quot;T&quot;&#10;ELSE &quot;F&quot;&#10;END' />
            </column>
            <column caption='F – Avg Engagement' datatype='real' name='[Calculation_1665206014266351622]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG(IF [Calculation_1665206014266163205] = &quot;F&quot; THEN [engagement] END) }' />
