      </column>
      <column caption='Time Bin (30s)' datatype='integer' name='[Calculation_1399845479951044608]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([time_seconds] / 30) * 30' />
      </column>
      <column caption='Engagement State ' datatype='string' name='[Calculation_1399845479951110145]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [engagement] &gt; 1.5 AND [cognitive_workload] &gt; 1.5 THEN &quot;Tense&quot;&#10;ELSEIF [engagement] &lt; 0.95 AND [cognitive_workload] &lt; 0.95 THEN &quot;Calm&quot;&#10;ELSE &quot;Moderate&quot;&#10;END' />
      </column>
      <column caption='I – Avg Engagement' datatype='real' name='[Calculation_1665206014264123392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [IE] = &quot;I&quot; THEN [engagement] END) }' />
      </column>
      <column caption='E – Avg Engagement' datatype='real' name='[Calculation_1665206014264221697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [IE] = &quot;E&quot; THEN [engagement] END) }' />
      </column>
      <column caption='S – Avg Engagement' datatype='real' name='[Calculation_1665206014264291330]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [SN] = &quot;S&quot; THEN [engagement] END) }' />
      </column>
      <column caption='N – Avg Engagement' datatype='real' name='[Calculation_1665206014264356867]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [SN] = &quot;N&quot; THEN [engagement] END) }' />
      </column>
      <column caption='T – Avg Engagement' datatype='real' name='[Calculation_1665206014264426500]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [Calculation_1665206014266163205] = &quot;T&quot; THEN [engagement] END) }' />
      </column>
      <column caption='TF Label' datatype='string' name='[Calculation_1665206014266163205]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [TF] THEN &quot;T&quot;&#10;ELSE &quot;F&quot;&#10;END' />
      </column>
      <column caption='F – Avg Engagement' datatype='real' name='[Calculation_1665206014266351622]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [Calculation_1665206014266163205] = &quot;F&quot; THEN [engagement] END) }' />
      </column>
      <column caption='J – Avg Engagement' datatype='real' name='[Calculation_1665206014266449927]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [JP] = &quot;J&quot; THEN [engagement] END) }' />
      </column>
      <column caption='P – Avg Engagement' datatype='real' name='[Calculation_1665206014266527752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG(IF [JP] = &quot;P&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Engagement Workload Divergence' datatype='real' name='[Calculation_1720586217937633280]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[engagement] - [cognitive_workload]' />
      </column>
      <column caption='Presentation Phase' datatype='string' name='[Calculation_2257288629914955776]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [time_seconds] &lt;= 150 THEN &quot;1 Early&quot;&#10;ELSEIF [time_seconds] &lt;= 450 THEN &quot;2 Middle&quot;&#10;ELSE &quot;3 Late&quot;&#10;END' />
      </column>
      <column caption='Phase Avg Engagement' datatype='real' name='[Calculation_2257288629917573121]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [IE], [Calculation_2257288629914955776] : AVG([engagement]) }' />
      </column>
      <column caption='Phase Avg Workload' datatype='real' name='[Calculation_2257288629917646850]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [IE], [Calculation_2257288629914955776] : AVG([cognitive_workload]) }' />
      </column>
      <column caption='Phase Eng - S' datatype='real' name='[Calculation_2257288629922238467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [SN] = &quot;S&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Phase Eng - N' datatype='real' name='[Calculation_2257288629922353156]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [SN] = &quot;N&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Phase Eng - T' datatype='real' name='[Calculation_2257288629922848773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [Calculation_1665206014266163205] = &quot;T&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Phase Eng - F' datatype='real' name='[Calculation_2257288629922951174]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [Calculation_1665206014266163205] = &quot;F&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Phase Eng - J' datatype='real' name='[Calculation_2257288629923037191]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [JP] = &quot;J&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Phase Eng - P' datatype='real' name='[Calculation_2257288629923102728]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [JP] = &quot;P&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Phase Eng - I' datatype='real' name='[Calculation_2257288629923352585]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [IE] = &quot;I&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Phase Eng - E' datatype='real' name='[Calculation_2257288629923418122]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2257288629914955776] : AVG(IF [IE] = &quot;E&quot; THEN [engagement] END) }' />
      </column>
      <column caption='Dominant Brainwave' datatype='string' name='[Calculation_2356790034200551424]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [alpha] &gt;= [beta] AND [alpha] &gt;= [theta] AND [alpha] &gt;= [delta] THEN &quot;Alpha&quot;&#10;ELSEIF [beta] &gt;= [alpha] AND [beta] &gt;= [theta] AND [beta] &gt;= [delta] THEN &quot;Beta&quot;&#10;ELSEIF [theta] &gt;= [alpha] AND [theta] &gt;= [beta] AND [theta] &gt;= [delta] THEN &quot;Theta&quot;&#10;ELSE &quot;Delta&quot;&#10;END' />
      </column>
      <column caption='Participant Avg Engagement' datatype='real' name='[Calculation_469218840662806528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [participant] : AVG([engagement]) }' />
      </column>
      <column caption='Engagement Volatility' datatype='real' name='[Calculation_469218840667029505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [participant] : STDEV([engagement]) }' />
      </column>
      <column caption='Mean Engagement' datatype='real' name='[Calculation_469218840667205634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [participant] : AVG([engagement]) }' />
      </column>
      <column caption='Jitter' datatype='real' name='[Calculation_469218840668319747]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANDOM() * 0.2' />
      </column>
      <column caption='Participant Filter' datatype='boolean' name='[Calculation_469218840669011972]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [participant] : MIN([time_seconds]) } = [time_seconds]' />
      </column>
