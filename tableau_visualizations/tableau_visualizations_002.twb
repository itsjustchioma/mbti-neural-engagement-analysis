            <column caption='Engagement Workload Divergence' datatype='real' name='[Calculation_1720586217937633280]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[engagement] - [cognitive_workload]' />
            </column>
            <column caption='Mbti' datatype='string' name='[MBTI]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1720586217937633280]' derivation='Avg' name='[avg:Calculation_1720586217937633280:qk]' pivot='key' type='quantitative' />
