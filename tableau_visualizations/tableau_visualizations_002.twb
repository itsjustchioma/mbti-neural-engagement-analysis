          </style-rule>
          <style-rule element='mark'>
            <encoding attr='color' center='0.0' field='[federated.0m07frz1lbw2je1as0pel1gpxlrf].[avg:Calculation_1720586217937633280:qk]' num-steps='5' palette='blue_10_0' symmetric='false' type='interpolated' />
